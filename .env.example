# .env.example — sample environment variables for this harness.
#
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.
#
# This file ships placeholder values only. Document EVERY required variable
# here so a fresh clone has a single place to look.

# ----------------------------------------------------------------------------
# GitHub
# ----------------------------------------------------------------------------

# Personal access token used by skills/cron jobs that talk to the GitHub API.
# Scopes needed: repo (read), pull_request (write for review-pr).
# Prefer `gh auth login` over a raw token where possible.
GH_TOKEN=

# ----------------------------------------------------------------------------
# Notification sinks (optional — used by some cron jobs)
# ----------------------------------------------------------------------------

# Slack incoming webhook for cron output (e.g. PR triage).
SLACK_WEBHOOK_URL=

# Generic email sink (e.g. for digest output).
NOTIFY_EMAIL=

# ----------------------------------------------------------------------------
# Cron job behaviour
# ----------------------------------------------------------------------------

# dependency-watch
DEPWATCH_FILE_ISSUE=0
DEPWATCH_THRESHOLD=high
DEPWATCH_LABEL=dependencies

# flaky-test-reporter
WORKFLOW=ci
RUNS=50
MIN_FAILURES=2

# ----------------------------------------------------------------------------
# YOUR project values go below
# ----------------------------------------------------------------------------

# Add database URLs, API keys, feature flags, etc. as your stack requires.
# Examples:
#
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0
# API_BASE_URL=https://api.example.com
# LOG_LEVEL=info
